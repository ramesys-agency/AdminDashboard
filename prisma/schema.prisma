generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String?
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Business {
  id        String       @id @default(cuid())
  name      String       @unique
  type      BusinessType
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  createdBy String?
  updatedBy String?
  agents    Agent[]
  clients   Client[]
  coupons   Coupon[]
  courses   Course[]
  enquiries Enquiry[]
  invoices  Invoice[]
  payments  Payment[]
  projects  Project[]
  students  Student[]
}

model Client {
  id         String    @id @default(cuid())
  businessId String
  name       String
  email      String    @unique
  phone      String?
  company    String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  createdBy  String?
  updatedBy  String?
  business   Business  @relation(fields: [businessId], references: [id])
  projects   Project[]
}

model Project {
  id          String    @id @default(cuid())
  businessId  String
  clientId    String
  name        String
  description String?
  status      String
  startDate   DateTime?
  endDate     DateTime?
  budget      Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String?
  updatedBy   String?
  invoices    Invoice[]
  payments    Payment[]
  business    Business  @relation(fields: [businessId], references: [id])
  client      Client    @relation(fields: [clientId], references: [id])
}

model Invoice {
  id          String    @id @default(cuid())
  businessId  String
  projectId   String?
  amount      Float
  status      String
  invoiceLink String?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String?
  updatedBy   String?
  business    Business  @relation(fields: [businessId], references: [id])
  project     Project?  @relation(fields: [projectId], references: [id])
  payments    Payment[]
}

model Student {
  id          String             @id @default(cuid())
  businessId  String
  name        String
  email       String             @unique
  phone       String?
  country     String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  createdBy   String?
  updatedBy   String?
  enrollments CourseEnrollment[]
  payments    Payment[]
  business    Business           @relation(fields: [businessId], references: [id])
}

model Course {
  id          String             @id @default(cuid())
  businessId  String
  slug        String             @unique
  name        String
  description String?
  price       Float
  priceINR    Float?
  priceUSD    Float?
  details     Json?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  createdBy   String?
  updatedBy   String?
  business    Business           @relation(fields: [businessId], references: [id])
  enrollments CourseEnrollment[]
}

model CourseEnrollment {
  id        String    @id @default(cuid())
  studentId String
  courseId  String
  status    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  course    Course    @relation(fields: [courseId], references: [id])
  student   Student   @relation(fields: [studentId], references: [id])
  payments  Payment[]
}

model Agent {
  id               String         @id @default(cuid())
  businessId       String
  name             String
  email            String         @unique
  phone            String?
  code             String         @unique
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  createdBy        String?
  updatedBy        String?
  additionalAmount Float          @default(0)
  commissionType   CommissionType @default(PERCENTAGE) // Same as discountType from Coupons
  commissionValue  Float          @default(10) // Same as discountValue from Coupons
  totalEarned      Float          @default(0)
  totalPaid        Float          @default(0)
  business         Business       @relation(fields: [businessId], references: [id])
  payments         Payment[]
}

model Coupon {
  id            String       @id @default(cuid())
  businessId    String
  code          String       @unique
  discountType  DiscountType @default(PERCENTAGE)
  discountValue Float        @default(10)
  maxUses       Int?
  currentUses   Int          @default(0)
  validUntil    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  createdBy     String?
  updatedBy     String?
  business      Business     @relation(fields: [businessId], references: [id])
  payments      Payment[]
}

model Enquiry {
  id         String   @id @default(cuid())
  businessId String
  name       String
  email      String
  phone      String?
  message    String?
  status     String   @default("NEW")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?
  updatedBy  String?
  business   Business @relation(fields: [businessId], references: [id])
}

model Payment {
  id                 String            @id @default(cuid())
  businessId         String
  amount             Float
  currency           String            @default("USD")
  status             String
  method             String?
  projectId          String?
  invoiceId          String?
  studentId          String?
  courseEnrollmentId String?
  agentId            String?
  couponId           String?
  razorpayOrderId    String?
  razorpayPaymentId  String?
  razorpaySignature  String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  createdBy          String?
  updatedBy          String?
  agent              Agent?            @relation(fields: [agentId], references: [id])
  business           Business          @relation(fields: [businessId], references: [id])
  coupon             Coupon?           @relation(fields: [couponId], references: [id])
  invoice            Invoice?          @relation(fields: [invoiceId], references: [id])
  project            Project?          @relation(fields: [projectId], references: [id])
  student            Student?          @relation(fields: [studentId], references: [id])
  courseEnrollment   CourseEnrollment? @relation(fields: [courseEnrollmentId], references: [id])
}

enum BusinessType {
  IT_SERVICES
  COURSE_SELLING
  OTHER
}

enum CommissionType {
  PERCENTAGE
  FLAT
}

enum DiscountType {
  PERCENTAGE
  FLAT
}
