generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Basic Admin/User model for dashboard access
model AdminUser {
  id       String  @id @default(cuid())
  name     String?
  email    String  @unique
  password String? // Add password field for traditional email/password login
  role     String  @default("ADMIN") // e.g., SUPERADMIN, ADMIN, VIEWER

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum BusinessType {
  IT_SERVICES
  COURSE_SELLING
  OTHER
}

model Business {
  id   String       @id @default(cuid())
  name String       @unique
  type BusinessType

  // Relations
  clients   Client[]
  projects  Project[]
  students  Student[]
  courses   Course[]
  enquiries Enquiry[]
  payments  Payment[]
  agents    Agent[]
  coupons   Coupon[]
  invoices  Invoice[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?
  updatedBy  String?
}

model Client {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  name       String
  email      String   @unique
  phone      String?
  company    String?

  projects Project[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?
  updatedBy  String?
}

model Project {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id])

  name        String
  description String?
  status      String // e.g., PENDING, IN_PROGRESS, COMPLETED
  startDate   DateTime?
  endDate     DateTime?
  budget      Float?

  invoices Invoice[]
  payments Payment[] // Payments towards this project

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?
  updatedBy  String?
}

model Invoice {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id])

  amount      Float
  status      String // PENDING, PAID, CANCELLED
  invoiceLink String? // URL/link for sending to clients
  dueDate     DateTime?

  payments Payment[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?
  updatedBy  String?
}

model Student {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  name  String
  email String  @unique
  phone String?

  enrollments CourseEnrollment[]
  payments    Payment[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?
  updatedBy  String?
}

model Course {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  name        String
  description String?
  price       Float

  enrollments CourseEnrollment[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?
  updatedBy  String?
}

model CourseEnrollment {
  id        String  @id @default(cuid())
  studentId String
  student   Student @relation(fields: [studentId], references: [id])
  courseId  String
  course    Course  @relation(fields: [courseId], references: [id])

  status String // ENROLLED, COMPLETED, DROPPED

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?
  updatedBy  String?
}

model Agent {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  name  String
  email String  @unique
  phone String?

  code            String @unique // The unique code generated for the agent
  discountPercent Float // Custom discount attached to this agent's code

  payments Payment[] // Payments made using this agent's code

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?
  updatedBy  String?
}

model Coupon {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  code            String    @unique
  discountPercent Float
  maxUses         Int?
  currentUses     Int       @default(0)
  validUntil      DateTime?

  payments Payment[] // Payments made using this coupon

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?
  updatedBy  String?
}

model Enquiry {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  name    String
  email   String
  phone   String?
  message String?

  status String @default("NEW") // NEW, CONTACTED, RESOLVED

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?
  updatedBy  String?
}

model Payment {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  amount Float
  status String // PENDING, COMPLETED, FAILED
  method String? // CARD, BANK_TRANSFER, UPI, etc.

  // Relations (optional/polymorphic based on what the payment is for)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  studentId String?
  student   Student? @relation(fields: [studentId], references: [id])

  courseEnrollmentId String?
  // We don't link directly to CourseEnrollment unless needed.
  // courseEnrollment   CourseEnrollment? @relation(fields: [courseEnrollmentId], references: [id])

  agentId String?
  agent   Agent?  @relation(fields: [agentId], references: [id])

  couponId String?
  coupon   Coupon? @relation(fields: [couponId], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?
  updatedBy  String?
}
